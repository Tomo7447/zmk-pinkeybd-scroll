#include "pinkeybd-layer.dtsi"
#include <input/processors.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include "pinkeybd-layouts.dtsi"

#define ZMK_POINTING_DEFAULT_SCRL_VAL 150

&lt { tapping-term-ms = <140>; };

&mt { flavor = "balanced"; };

&mkp_input_listener { input-processors = <&zip_temp_layer 5 300>; };

&kscan0 {
    debounce-press-ms = <1>;
    debounce-release-ms = <5>;
};

/ {
    behaviors {
        encoder_msc_down_up: encoder_msc_down_up {
            compatible = "zmk,behavior-sensor-rotate";
            label = "ENCODER_MSC_DOWN_UP";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

            tap-ms = <40>;
        };

        my_lt: layer_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <250>;
            bindings = <&mo>, <&kp>;

            display-name = "Layer-Tap";
        };

        minus_single: minus_single {
            compatible = "zmk,behavior-mod-morph";
            label = "MINUS_SINGLE";
            bindings = <&kp MINUS>, <&kp LS(N7)>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        slash_double: slash_double {
            compatible = "zmk,behavior-mod-morph";
            label = "SLASH_DOUBLE";
            bindings = <&kp SLASH>, <&kp AT_SIGN>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        period_exclamation: period_exclamation {
            compatible = "zmk,behavior-mod-morph";
            label = "PERIOD_EXCLAMATION";
            bindings = <&kp PERIOD>, <&kp EXCL>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        comma_question: comma_question {
            compatible = "zmk,behavior-mod-morph";
            label = "COMMA_QUESTION";
            bindings = <&kp COMMA>, <&kp QUESTION>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };
    };

    combos {
        compatible = "zmk,combos";

        left_kakko {
            bindings = <&kp LS(N8)>;
            key-positions = <2 3>;
            layers = <0 1>;
        };

        right_kakko {
            bindings = <&kp LS(N9)>;
            key-positions = <3 4>;
            layers = <0 1>;
        };

        left_kagi {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <13 14>;
            layers = <0 1>;
        };

        right_kagi {
            bindings = <&kp NUHS>;
            key-positions = <14 15>;
            layers = <0 1>;
        };

        syounari {
            bindings = <&kp LS(COMMA)>;
            key-positions = <24 25>;
            layers = <0 1>;
        };

        dainari {
            bindings = <&kp LS(PERIOD)>;
            key-positions = <25 26>;
            layers = <0 1>;
        };

        left_boot_reset {
            bindings = <&bootloader>;
            key-positions = <0 1 2 3>;
            layers = <0>;
        };

        right_boot_reset {
            bindings = <&bootloader>;
            key-positions = <7 8 9 10>;
            layers = <0>;
        };

        middle_mouse_click {
            bindings = <&mkp MCLK>;
            key-positions = <38 40>;
            layers = <0 1>;
        };

        Backspace {
            bindings = <&kp BACKSPACE>;
            key-positions = <39 18>;
            layers = <0 1>;
        };

        Shift {
            bindings = <&kp LEFT_SHIFT>;
            key-positions = <39 35>;
            layers = <0 1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        /       |       ,       |       .       |      -        |      ;       |    ESC         |                   |           |       L      |       R       |       D       |       Y       |      P      |
        // |        A       |       O       |       E       |      I        |      U       |    SCROLLLOCK  |                   |           |       G      |       N       |       T       |       S       |      K      |
        // |        X       |       C       |       V       |      W        |      F       |    TAB         |                   |     Q     |       J      |       H       |       M       |       B       |      Z      |
        // |    L_SHIFT     |               |               |    Space      |   LOWER / Jp |    LEFT_WIN    |                   |  R_SHIFT  |      ENTER   |   NUM_L / Ja  |               |               |   RCTRL     |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        default_layer {
            bindings = <
&kp Q             &kp W  &kp E      &kp R  &kp T                                &mt LG(LS(S)) LG(PERIOD)  &kp Y      &kp U      &kp I             &kp O                &kp P
&kp A             &kp S  &kp D      &kp F  &kp G                                &none                     &kp H      &kp J      &kp K             &kp L                &minus_single
&mt LEFT_SHIFT Z  &kp X  &kp C      &kp V  &kp B                                &mt F10 F7                &kp N      &kp M      &comma_question   &period_exclamation  &slash_double
&mt LCTRL TAB     &mo 2  &kp SPACE  &mo 1  &mt INTERNATIONAL_5 INTERNATIONAL_4  &mkp LCLK                 &kp ENTER  &mkp RCLK  &mt LEFT_ALT DEL
            >;

            sensor-bindings = <&inc_dec_kp DOWN_ARROW UP_ARROW>;
        };

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       <       |       >       |       _       |      ”        |    PAUSE_BREAK|                  |            |      （       |       ）     |        ↑      |        [      |    ]        |
        // |    LC(A)       |       LC(S)   |       END     |       LS(F)   |       U       |    SCROLLLOCK |                  |            |   Backspace   |       ←      |        ↓      |        →      |    DEL      |
        // |    UNDERSCORE  |       CUT     |       COPY    |       PASTE   |       LALT    |    TAB        |                  |   PSCRN    |    ' / "      |    = / +     |    \ / |      |    ` / ~      |    PIPE     |
        // |    L_SHIFT     |               |               |       LALT    |       none    |    SPACE      |                  |   RSHIFT   |   ENTER       |    LOWER2    |               |               |    RCTRL    |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        symbol_and_number {
            bindings = <
&none  &kp LEFT_BRACKET  &kp HASH     &kp SINGLE_QUOTE  &none   &none      &kp N7        &kp N8        &kp N9             &kp LS(MINUS)            &kp LS(SEMI)
&none  &kp LS(NUMBER_6)  &kp PERCENT  &kp SEMI          &none   &none      &kp NUMBER_4  &kp N5        &kp NUMBER_6       &kp LS(INTERNATIONAL_1)  &kp MINUS
&none  &none             &none        &none             &none   &none      &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3       &kp PERIOD               &kp SLASH
&none  &none             &kp SPACE    &none             &kp N0  &mkp LCLK  &kp ENTER     &mkp RCLK     &kp DOUBLE_QUOTES
            >;

            sensor-bindings = <&encoder_msc_down_up>;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       ,        |       END     |      C_VOL_UP    |       ’      |    ESC        |                  |            |      {      |      }         |    PG_UP      |     {       |      }    |
        // |    HOME        |       C_SAVE   |       END     |      C_VOL_DN    |   C_MUTE     |    SCROLLLOCK |                  |            |  Backspace  |    HOME        |    PG_DN      |    END      |   DEL     |
        // |    UNDO        |       CUT      |       COPY    |      WIN_PASTE   |       Q      |    TAB        |                  |   PSCRN    |    ' / "    |    = / +       |    \ / |      |    ` / ~    |   INS     |
        // |    L_SHIFT     |                |               |      LCTRL       |       none   |    SPACE      |                  |   ENTER    |    none     |   R_SHIFT      |               |             |   RCTRL   |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        arrow {
            bindings = <
&kp C_MUTE         &none  &kp ESCAPE  &none  &none  &none          &kp HOME  &none           &kp UP_ARROW    &none            &none
&kp C_VOLUME_DOWN  &none  &none       &none  &none  &none          &kp END   &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &none
&kp C_VOLUME_UP    &none  &none       &none  &mo 6  &none          &none     &none           &none           &none            &none
&kp LG(H)          &none  &none       &none  &none  &kp PAGE_DOWN  &none     &kp PAGE_UP     &none
            >;

            sensor-bindings = <&encoder_msc_down_up>;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        1       |      2        |       3       |       4       |       5       |    ESC        |               |            |      6       |      7        |       8       |       9       |       0       |
        // |        !       |      @        |       #       |       $       |       %       |    none       |               |            |      ^       |      &        |       *       |       (       |       )       | 
        // |    PLUS        |   UNDERSCORE  |   QUESTION    |    COLON      |       DQT     |    TAB        |               |   TILDE    |    ' / "     |    = / +      |    \ / |      |    ` / ~      |       PIPE    |
        // |    L_SHIFT     |               |               |    LALT       |   Func_layer  |    SPACE      |               |   R_SHIFT  |      ENTER   |     none      |               |               |       RCTRL   |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        no {
            bindings = <
&kp N1      &kp N2      &kp N3      &kp N4      &kp N5      &kp ESC     &kp N6      &kp N7      &kp N8      &kp N9      &kp N0
&kp LS(N1)  &kp LS(N2)  &kp LS(N3)  &kp LS(N4)  &kp LS(N5)  &none       &kp RS(N6)  &kp RS(N7)  &kp RS(N8)  &kp RS(N9)  &kp RS(N0)
&kp PLUS    &kp UNDER   &kp QMARK   &kp COLON   &kp DQT     &kp TAB     &kp APOS    &kp EQUAL   &kp BSLH    &kp GRAVE   &kp PIPE
&mo LSHIFT  &kp LALT    &mo FUNC_L  &kp SPACE   &kp TILDE   &kp RSHIFT  &kp ENTER   &none       &kp RCTRL
            >;
        };

        // ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |     F1      |     F2     |     F3     |     F4     |    F5      |    C_VOL_UP  |                |            |    F6      |    F7      |    F8      |    F9       |     F10      |
        // |     F11     |     F12    |     F13    |     F14    |    F15     |    none      |                |            |    F16     |    F17     |    F18     |    F19      |     F20      |
        // |     none    |    none    |    none    |    none    |   none     |    C_VOL_DN  |                | RIGHT_WIN  |    none    |    none    |    none    |    none     |     none     |
        // |     L_SHIFT |            |            |    LALT    |   none     |    none      |                |   RCTRL    |    none    |    none    |            |             |  Bt_layer    |
        // ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        not {
            bindings = <
&kp F1      &kp F2    &kp F3   &kp F4   &kp F5         &kp C_VOL_UP  &kp F6   &kp F7   &kp F8    &kp F9   &kp F10
&kp F11     &kp F12   &kp F13  &kp F14  &kp F15        &none         &kp F16  &kp F17  &kp F18   &kp F19  &kp F20
&none       &none     &none    &none    &none          &kp C_VOL_DN  &none    &none    &none     &none    &none
&kp LSHIFT  &kp LALT  &none    &none    &kp RIGHT_WIN  &kp RCTRL     &none    &none    &mo BT_L
            >;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    none    |    none    |    none    |    none    |   none     |    ESC     |                  |            |    MCLK    |    none    |    none    |   none     |    none    |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |            |    none    |    RCLK    |    MB4     |   MB5      |    none    |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  | C_PREVIOUS |    C_NEXT  |    none    |    none    |   none     |    none    |
        // |    L_SHIFT |            |            |    none    |   none     |    none    |                  |    LCLK    |    none    |    none    |            |            |    RCTRL   |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Mouse_layer {
            bindings = <
&none       &none      &none  &none  &none  &kp ESC    &mkp MCLK       &none       &none      &none     &none
&none       &none      &none  &none  &none  &none      &none           &mkp RCLK   &mkp MB4   &mkp MB5  &none
&none       &none      &none  &none  &none  &none      &kp C_PREVIOUS  &kp C_NEXT  &none      &none     &none
&kp LSHIFT  &kp LCTRL  &none  &none  &none  &mkp LCLK  &none           &none       &kp RCTRL
            >;

            sensor-bindings = <&encoder_msc_down_up>;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |  BT_SEL 0  |  BT_SEL 1  |  BT_SEL 2  |  BT_SEL 3  |            |            |                  |            |    none    |    none    |    none    |   BT_CLR   | BT_CLR_ALL |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |    none    |    none    |   BT_PRV   |    none    |   BT_NXT   |    none    |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |    none    |    none    |    none    |    none    |   none     |    none    |
        // |    none    |            |            |    none    |   none     |    none    |                  |    none    |    none    |    none    |            |            |    none    |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Bt_layer {
            bindings = <
&none  &none  &none  &none  &none  &none  &none         &none         &none         &none  &none
&none  &none  &none  &none  &none  &none  &none         &none         &none         &none  &none
&none  &none  &none  &none  &none  &none  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &none  &none
&none  &none  &none  &none  &none  &none  &none         &none         &none
            >;
        };
    };
};
